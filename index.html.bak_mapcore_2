    <!-- Footer -->
    <footer>
        <div class="container">
            <div class="footer-logo">SAT-DISCOVERY</div>
            <div class="footer-links">
                <a href="data_sources.html">数据源</a>
                <a href="algorithms.html">算法库</a>
                <a href="login.html">登录</a>
