<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SAT-DISCOVERY - 卫星数据算法处理平台</title>
    <link rel="stylesheet" href="css/cyber-theme.css">
    <style>
        /* 导航栏 */
        nav {
            background: var(--gradient-panel);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--border-primary);
            padding: 20px 0;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 10px rgba(0, 212, 255, 0.1);
        }
        
        nav .container {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .nav-logo {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--cyan-bright);
            text-shadow: var(--glow-sm);
            text-decoration: none;
        }
        
        .nav-menu {
            display: flex;
            gap: 32px;
            list-style: none;
        }
        
        .nav-menu a {
            color: var(--text-secondary);
            text-decoration: none;
            transition: all var(--transition-base);
            position: relative;
        }
        
        .nav-menu a::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 2px;
            background: var(--cyan-bright);
            box-shadow: var(--glow-sm);
            transition: width var(--transition-base);
        }
        
        .nav-menu a:hover {
            color: var(--cyan-bright);
        }
        
        .nav-menu a:hover::after {
            width: 100%;
        }
        
        /* Hero区域 */
        .hero {
            padding: 100px 0;
            text-align: center;
        }
        
        .hero h1 {
            font-size: 3.5rem;
            margin-bottom: 24px;
            background: linear-gradient(135deg, #00d4ff 0%, #0ea5e9 50%, #06b6d4 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            filter: drop-shadow(0 0 30px rgba(0, 212, 255, 0.6));
            animation: pulse-glow 3s ease-in-out infinite;
        }
        
        .hero-subtitle {
            font-size: 1.5rem;
            color: var(--text-secondary);
            margin-bottom: 16px;
        }
        
        .hero-description {
            max-width: 700px;
            margin: 0 auto 40px;
            color: var(--text-muted);
            font-size: 1.1rem;
            line-height: 1.8;
        }
        
        .hero-buttons {
            display: flex;
            gap: 20px;
            justify-content: center;
            flex-wrap: wrap;
        }
        
        /* 特性网格 */
        .features-section {
            padding: 80px 0;
        }
        
        .section-title {
            text-align: center;
            font-size: 2.5rem;
            margin-bottom: 60px;
            color: var(--cyan-bright);
            text-shadow: var(--glow-sm);
        }
        
        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
        }
        
        .feature-card {
            background: var(--gradient-panel);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-primary);
            border-radius: var(--radius-md);
            padding: 40px 32px;
            transition: all var(--transition-base);
            position: relative;
            overflow: hidden;
        }
        
        .feature-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(0, 212, 255, 0.1), transparent);
            transition: left 0.6s;
        }
        
        .feature-card:hover {
            border-color: var(--cyan-bright);
            box-shadow: var(--glow-lg);
            transform: translateY(-10px);
        }
        
        .feature-card:hover::before {
            left: 100%;
        }
        
        .feature-number {
            display: inline-block;
            width: 50px;
            height: 50px;
            line-height: 50px;
            text-align: center;
            background: rgba(0, 212, 255, 0.1);
            border: 2px solid var(--cyan-bright);
            border-radius: 50%;
            color: var(--cyan-bright);
            font-weight: 700;
            font-size: 1.3rem;
            margin-bottom: 20px;
            box-shadow: var(--glow-md);
        }
        
        .feature-card h3 {
            color: var(--text-primary);
            margin-bottom: 12px;
            font-size: 1.4rem;
        }
        
        .feature-card p {
            color: var(--text-secondary);
            line-height: 1.7;
        }
        
        /* 统计数据 */
        .stats-section {
            padding: 80px 0;
            background: var(--gradient-cyber);
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 30px;
        }
        
        .stat-card {
            background: var(--gradient-panel);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-primary);
            border-radius: var(--radius-md);
            padding: 40px 20px;
            text-align: center;
            position: relative;
        }
        
        .stat-card::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--cyan-bright);
            box-shadow: var(--glow-md);
        }
        
        .stat-value {
            font-size: 3rem;
            font-weight: 700;
            color: var(--cyan-bright);
            text-shadow: var(--glow-md);
            display: block;
            margin-bottom: 12px;
        }
        
        .stat-label {
            color: var(--text-secondary);
            font-size: 1rem;
        }
        
        /* CTA区域 */
        .cta-section {
            padding: 100px 0;
            text-align: center;
        }
        
        .cta-panel {
            background: var(--gradient-panel);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-primary);
            clip-path: polygon(
                0 0, 
                calc(100% - 30px) 0, 
                100% 30px, 
                100% 100%, 
                30px 100%, 
                0 calc(100% - 30px)
            );
            padding: 60px 40px;
            max-width: 800px;
            margin: 0 auto;
            position: relative;
        }
        
        .cta-panel::before {
            content: '';
            position: absolute;
            top: -1px;
            right: -1px;
            width: 35px;
            height: 35px;
            border-top: 3px solid var(--cyan-bright);
            border-right: 3px solid var(--cyan-bright);
            box-shadow: var(--glow-md);
        }
        
        .cta-panel::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: -1px;
            width: 35px;
            height: 35px;
            border-bottom: 3px solid var(--cyan-bright);
            border-left: 3px solid var(--cyan-bright);
            box-shadow: var(--glow-md);
        }
        
        .cta-panel h2 {
            font-size: 2.5rem;
            margin-bottom: 20px;
        }
        
        .cta-panel p {
            color: var(--text-secondary);
            font-size: 1.2rem;
            margin-bottom: 30px;
        }
        
        /* Footer */
        footer {
            padding: 60px 0 30px;
            border-top: 1px solid var(--border-secondary);
            text-align: center;
        }
        
        .footer-logo {
            font-size: 1.8rem;
            color: var(--cyan-bright);
            text-shadow: var(--glow-sm);
            margin-bottom: 20px;
        }
        
        .footer-links {
            display: flex;
            gap: 30px;
            justify-content: center;
            margin-bottom: 30px;
        }
        
        .footer-links a {
            color: var(--text-secondary);
            text-decoration: none;
        }
        
        .footer-copyright {
            color: var(--text-muted);
            font-size: 0.9rem;
        }
        
        @media (max-width: 768px) {
            .hero h1 { font-size: 2.5rem; }
            .nav-menu { gap: 20px; }
            .cta-panel { clip-path: none; }
        }
    </style>
  <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.css">
  <script src="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.js"></script>
</head>
